{
  "name": "my-code",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "npm run cf-typegen && tsx ./scripts/checkDocs.ts && tsx ./scripts/generateDocsMeta.ts && tsx ./scripts/copyAllDTSFiles.ts && tsx ./scripts/removeHinting.ts",
    "dev": "npm run prebuild && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "npm run cf-typegen && next lint",
    "tsc": "npm run cf-typegen && tsc",
    "format": "prettier --write app/ packages/",
    "checkDocs": "tsx ./scripts/checkDocs.ts",
    "cf-preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --port 3000",
    "cf-deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@fontsource-variable/inconsolata": "^5.2.7",
    "@fontsource/m-plus-rounded-1c": "^5.2.9",
    "@google/genai": "^1.21.0",
    "@opennextjs/cloudflare": "^1.16.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.1.0-beta.168",
    "ace-builds": "^1.43.2",
    "better-auth": "^1.4.5",
    "chalk": "^5.5.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "js-yaml": "^4.1.1",
    "mocha": "^11.7.4",
    "next": "^15.5.11",
    "pg": "^8.16.3",
    "prismjs": "^1.30.0",
    "react": "^19",
    "react-ace": "^14.0.1",
    "react-dom": "^19",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-cjk-friendly": "^1.2.3",
    "remark-gfm": "^4.0.1",
    "remark-remove-comments": "^1.1.1",
    "swr": "^2.3.6",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@pyodide/webpack-plugin": "^1.4.0",
    "@tailwindcss/postcss": "^4",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20",
    "@types/pako": "^2.0.4",
    "@types/pg": "^8.15.5",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "daisyui": "^5.5.5",
    "drizzle-kit": "^0.31.5",
    "eslint": "^9",
    "eslint-config-next": "^15.5.11",
    "fonteditor-core": "^2.6.3",
    "pako": "^2.1.0",
    "prettier": "^3.6.2",
    "prisma": "^6.18.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "5.9.3",
    "wrangler": "^4.27.0"
  }
}
